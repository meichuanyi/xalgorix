{
  "name": "@xalgorix/dashboard",
  "version": "0.0.0",
  "private": true,
  "description": "Authenticated Dashboard for Xalgorix Cloud_Platform (app.xalgorix.com). Implements Requirement 6 and design.md `web/app`.",
  "scripts": {
    "dev": "next dev --port 3001",
    "build": "next build",
    "start": "next start --port 3001",
