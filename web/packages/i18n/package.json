{
  "name": "@xalgorix/i18n",
  "version": "0.0.0",
  "private": true,
  "description": "next-intl message catalogs and missing-key logger for Xalgorix SaaS frontends. Implements design.md `web/packages/i18n` and Requirement 18.7.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./messages/*": "./src/messages/*.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint . --max-warnings=0",
    "test": "echo \"@xalgorix/i18n has no tests yet\" && exit 0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "devDependencies": {
    "@xalgorix/eslint-config": "workspace:*",
    "@xalgorix/tsconfig": "workspace:*",
    "typescript": "^5.5.4"
  }
}
