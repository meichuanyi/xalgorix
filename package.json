{
  "name": "xalgorix-saas",
  "private": true,
  "version": "0.0.0",
  "description": "Xalgorix SaaS — Cloud_Platform web monorepo (marketing, dashboard, admin) wrapping the Go Scan_Engine.",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "workspaces": [
    "web/marketing",
    "web/app",
    "web/admin",
    "web/packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "dev": "turbo run dev --parallel",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.1.3",
    "typescript": "^5.5.4"
  }
}
